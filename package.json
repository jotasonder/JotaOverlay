{
  "name": "jota-overlay",
  "version": "0.2.1",
  "description": "Rocket League Tournament Overlay by jotasonder",
  "author": "jotasonder",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "es.jotasonder.rl-overlay",
    "productName": "JotaOverlay",
    "asar": true,
    "copyright": "JotaOverlay",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": ["portable"]
    },
    "files": [
      "main.js",
      "server.js",
      "overlay/**/*",
      "control-panel/**/*",
      "assets/**/*",
      "data/**/*"
    ]
  }
}
